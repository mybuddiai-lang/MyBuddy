# ============================================================
# Buddi v2.0 — Environment Configuration
# ============================================================
# Copy this file to .env (root) and backend/.env, then fill in values.
#
# PRODUCTION SETUP (Railway):
#   Backend service  → set all vars below EXCEPT NEXT_PUBLIC_*
#   Frontend service → set NEXT_PUBLIC_API_URL and NEXT_PUBLIC_APP_NAME
#                      as Build Variables (not runtime) in Railway UI
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Your Railway frontend URL (no trailing slash)
# Example: https://buddi-frontend.up.railway.app
FRONTEND_URL=https://your-frontend.up.railway.app

# ─── Database ────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/buddi_db

# ─── Redis ───────────────────────────────────────────────────
# Railway provides this automatically when you add a Redis plugin
# Use REDIS_URL (preferred) — individual params also supported as fallback
REDIS_URL=redis://default:PASSWORD@HOST:6379

# ─── JWT Auth ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-64-char-random-hex-string
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-hex-string

# ─── AI Providers ────────────────────────────────────────────
# Primary: OpenAI (used for chat + sentiment + summarisation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic (for future provider switch)
ANTHROPIC_API_KEY=sk-ant-...

# ─── AWS S3 (file/slide storage) ─────────────────────────────
# Create an S3 bucket and IAM user with PutObject + DeleteObject permissions
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=buddi-uploads

# ─── Stripe (global payments) ────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Paystack (Nigerian / African payments) ──────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ─── Email (SMTP) ────────────────────────────────────────────
# Gmail: enable 2FA, create an App Password at myaccount.google.com/apppasswords
# SendGrid: host=smtp.sendgrid.net port=587 user=apikey pass=<api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=noreply@buddi.app

# ─── Google OAuth ────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: https://your-backend.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=https://your-backend.up.railway.app/api/auth/google/callback

# ─── Web Push (VAPID) ────────────────────────────────────────
# Pre-generated — safe to use, regenerate if compromised:
#   node -e "const w=require('web-push'); const k=w.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=BOLPwTYehtfuaw187W4hIZa9RlWGtQv8Xqq40eKnn2s9xLP0fFWQRRDZVzpOMPa_42VPKMyWH1ZyJqPIKaWuj00
VAPID_PRIVATE_KEY=y6hXqZ3ldCwPTpkmmb_PFPsNuOsyDXv7C6tPb6lXoZY
VAPID_SUBJECT=mailto:support@buddi.app

# ─── Frontend (build-time only) ──────────────────────────────
# Set these as Build Variables in Railway's frontend service settings
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api
NEXT_PUBLIC_APP_NAME=Buddi
